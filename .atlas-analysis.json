  "keyFeatures": [
    "User Management (view, create, edit, delete users with pagination and search)",
    "Organization & Team Management (manage organizations, teams, and members)",
    "Session Management (view active sessions with IP geolocation support)",
    "Event Tracking & Analytics (real-time event ingestion and monitoring)",
    "Multi-Database Support (Prisma, Drizzle, SQLite, PostgreSQL, MySQL)",
    "Multi-Framework Adapters (Next.js, Express, Hono, SvelteKit, Remix, Nuxt, and more)",
    "CLI Tool (start studio with customizable options and watch mode)",
    "Self-Hosting (deploy alongside your application with access control)",
    "Developer Tools (OAuth testing, password hashing, JWT decoder, token generator)",
    "Real-time Updates (WebSocket support for live config changes)",
    "Bulk Operations (seed test users, organizations, and teams)",
    "Last Seen Tracking (automatic user activity tracking)"
  ],
  "publicApiSurface": [
    "better-auth-studio start (CLI command to start the studio)",
    "better-auth-studio init (CLI command to initialize self-hosting configuration)",
